# Supabase Configuration
# Get your credentials from: https://supabase.com/dashboard/project/bheohnfxjnwdkqvftbnc/settings/api

# Your Supabase project URL (automatically generated from project ref)
SUPABASE_URL=https://bheohnfxjnwdkqvftbnc.supabase.co

# Your Supabase anon/public key
# Find it at: Supabase Dashboard > Project Settings > API > anon/public key
